{
  "name": "nightmare-library-cloudflare",
  "version": "1.0.0",
  "description": "Nightmare Library - Cloudflare Pages Version",
  "type": "module",
  "scripts": {
    "dev": "wrangler pages dev . --compatibility-date=2024-01-01",
    "build": "echo 'No build step required for vanilla frontend'",
    "deploy": "wrangler pages deploy .",
    "db:migrate": "wrangler d1 execute nightmare-library-db --remote --file=./migrations/0001_init.sql"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240117.0",
    "typescript": "^5.3.3",
    "wrangler": "^3.22.4"
  },
  "dependencies": {
    "hono": "^3.12.6"
  }
}
