modules = ["nodejs-20"]
[agent]
expertMode = true

[workflows]
runButton = "Info"

[[workflows.workflow]]
name = "Info"
mode = "sequential"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "echo '╔════════════════════════════════════════════════════════╗' && echo '║   Nightmare Library - Cloudflare Pages Project        ║' && echo '╚════════════════════════════════════════════════════════╝' && echo '' && echo 'This project is designed for Cloudflare Pages deployment.' && echo '' && echo '📖 Setup Guide: See CLOUDFLARE_SETUP.md' && echo '🚀 Deploy: npm run deploy' && echo '🧪 Local Test: npm run dev' && echo '' && echo 'Note: This Repl is for development only.' && echo 'Deploy to Cloudflare Pages for production use.'"

[[ports]]
localPort = 8788
externalPort = 80
